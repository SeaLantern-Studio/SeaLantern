	optdepends = gst-plugins-bad: GStreamer 额外插件
	optdepends = gst-plugins-ugly: GStreamer 非自由插件
	optdepends = noto-fonts: 更好的字体显示
	optdepends = noto-fonts-cjk: 中日韩字体支持
	optdepends = noto-fonts-emoji: 表情符号支持
	options = !strip
