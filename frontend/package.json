{
  "name": "sea-lantern",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "next": "node ./scripts/dev.mjs next",
    "next:auth": "node ./scripts/dev.mjs next:auth",
    "next:home": "node ./scripts/dev.mjs next:home",
    "next:servers": "node ./scripts/dev.mjs next:servers",
    "next:plugins": "node ./scripts/dev.mjs next:plugins",
    "next:settings": "node ./scripts/dev.mjs next:settings",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "i18n:sync": "node ./scripts/sync-i18n.mjs",
    "i18n:check": "node ./scripts/check-i18n.mjs",
    "preview": "vite preview",
    "tauri": "node ../scripts/tauri.mjs",
    "tauri:dev": "pnpm run tauri:dev:desktop-full",
    "tauri:dev:desktop-full": "pnpm run tauri dev:desktop-full",
    "tauri:dev:desktop-min": "pnpm run tauri dev:desktop-min",
    "tauri:build": "pnpm run tauri:build:desktop-full",
    "tauri:build:desktop-full": "pnpm run tauri build:desktop-full",
    "tauri:build:desktop-min": "pnpm run tauri build:desktop-min",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "notice": "node ../scripts/notice.mjs",
    "sv": "node ../scripts/version.mjs show",
    "cv": "node ../scripts/version.mjs change",
    "dev:http:backend": "cargo run -p docker-entry",
    "docker:dev": "pnpm run dev:http:backend",
    "docker:build": "docker build -t sealantern:docker ."
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@headlessui/vue": "^1.7.23",
    "@lezer/highlight": "^1.2.3",
    "@lucide/vue": "^1.17.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^14.3.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.8",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.9",
    "simple-icons": "^16.23.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "glob": "^13.0.6",
    "license-checker-rseidelsohn": "^5.0.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "sass-embedded": "^1.100.0",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.4"
  },
  "overrides": {
    "brace-expansion@2.0.2": "2.0.3",
    "brace-expansion@5.0.4": "5.0.6",
    "fast-uri@3.1.0": "3.1.2",
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3"
  },
  "packageManager": "pnpm@11.5.3"
}
