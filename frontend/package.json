{
  "name": "sea-lantern",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "node ../scripts/tauri.mjs",
    "tauri:dev": "pnpm run tauri dev",
    "tauri:build": "pnpm run tauri build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "notice": "node ../scripts/notice.mjs",
    "sv": "node ../scripts/version.mjs show",
    "cv": "node ../scripts/version.mjs change",
    "docker:dev": "cargo run -p docker-entry",
    "docker:build": "docker build -t sealantern:docker ."
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
